# =============================================================================
# Platform Settings
# =============================================================================
APP_ENV=development                    # development | staging | production
APP_DEBUG=true                         # Enable debug mode
APP_SECRET_KEY=change-me-in-production # Used for JWT signing, session encryption
APP_LOG_LEVEL=DEBUG                    # DEBUG | INFO | WARNING | ERROR

# =============================================================================
# Broker
# =============================================================================
POCKET_OPTION_SSID=                    # Session ID from browser cookies
POCKET_OPTION_URL=                     # (optional) Custom broker URL
POCKET_OPTION_MAX_SUBSCRIPTIONS=4      # Max concurrent symbol subscriptions
POCKET_OPTION_CONNECTION_TIMEOUT=30    # Connection timeout in seconds
POCKET_OPTION_RECONNECT_DELAY=5        # Base reconnection delay in seconds

# =============================================================================
# Telegram
# =============================================================================
TELEGRAM_BOT_TOKEN=                    # Bot token from @BotFather
TELEGRAM_ALLOWED_USER_IDS=             # Comma-separated Telegram user IDs allowed to use the bot
TELEGRAM_ADMIN_USER_IDS=              # Comma-separated admin user IDs
TELEGRAM_POLLING=true                  # true = polling, false = webhook
TELEGRAM_WEBHOOK_URL=                  # (required if polling=false)
TELEGRAM_WEBHOOK_PORT=8443             # (required if polling=false)
TELEGRAM_RATE_LIMIT_GLOBAL=30          # Max messages/second to Telegram API
TELEGRAM_RATE_LIMIT_PER_USER=10        # Max commands/minute per user
TELEGRAM_MAX_SUBSCRIPTIONS_PER_USER=5  # Max signal subscriptions per user

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql+asyncpg://trader:devpassword@localhost:5432/trading
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_CONNECT_TIMEOUT=30
DUCKDB_PATH=storage/analytics.duckdb   # Path to DuckDB analytics database

# =============================================================================
# Cache & Events (Redis)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_CACHE_TTL=300                    # Default cache TTL in seconds

# =============================================================================
# Trading
# =============================================================================
TRADING_DEFAULT_AMOUNT=10.0            # Default trade amount in USD
TRADING_DEFAULT_TIMEFRAME=60           # Default option duration in seconds
TRADING_MAX_DAILY_TRADES=50            # Max trades per day across all strategies
TRADING_MAX_POSITION_SIZE=100.0        # Max single trade amount
TRADING_COOLDOWN_SECONDS=30            # Min seconds between trades on same symbol

# =============================================================================
# Signal Pipeline
# =============================================================================
SIGNAL_CONFIDENCE_THRESHOLD=0.65       # Minimum confidence to execute a trade
SIGNAL_MIN_WINS_TO_ACTIVATE=10         # Min backtest wins before going live
SIGNAL_MAX_FEATURES=50                 # Max features in a feature set

# =============================================================================
# MLflow (Experiment Tracking)
# =============================================================================
MLFLOW_TRACKING_URI=mlruns             # Local directory or remote server URI
MLFLOW_EXPERIMENT_NAME=trading         # Default experiment name
MLFLOW_MODEL_REGISTRY_URI=mlruns       # Model registry URI

# =============================================================================
# Market Data Providers (Optional)
# =============================================================================
ALPHA_VANTAGE_KEY=
TWELVE_DATA_KEY=
DUKASCOPY_DATA_PATH=

# =============================================================================
# AI APIs (Optional — for experimental signal generation)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# =============================================================================
# Monitoring
# =============================================================================
METRICS_PORT=9090                      # Prometheus metrics endpoint port
HEALTH_CHECK_PORT=8080                 # Health check HTTP port